generator client { provider = "prisma-client-js" }
datasource db { provider = "postgresql"; url = env("DATABASE_URL") }
model User {
  id    String @id
  email String @unique
}
model PasswordResetToken {
  token   String   @id
  expires DateTime
}
model ApiKey {
  id        String    @id
  hashedKey String    @unique
  lastUsedAt DateTime?
}
