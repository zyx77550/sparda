{
  "openapi": "3.0.3",
  "info": { "title": "any-backend-on-earth", "version": "1.0.0" },
  "security": [{ "bearerAuth": [] }],
  "components": {
    "securitySchemes": {
      "bearerAuth": { "type": "http", "scheme": "bearer" }
    },
    "schemas": {
      "Order": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "amount": { "type": "number" },
          "status": { "type": "string" }
        }
      }
    }
  },
  "paths": {
    "/orders/{orderId}": {
      "parameters": [
        { "name": "orderId", "in": "path", "required": true, "schema": { "type": "integer" } }
      ],
      "get": {
        "operationId": "getOrder",
        "summary": "Fetch one order",
        "security": [],
        "responses": {
          "200": {
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Order" } }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteOrder",
        "responses": { "204": { "description": "gone" } }
      }
    },
    "/orders": {
      "post": {
        "operationId": "createOrder",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/Order" } }
          }
        },
        "responses": {
          "201": {
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Order" } }
            }
          }
        }
      }
    }
  }
}
