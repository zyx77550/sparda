{
  "name": "sparda-mcp",
  "version": "0.8.1",
  "mcpName": "io.github.zyx77550/sparda-mcp",
  "description": "Turn any codebase into an MCP server with one command. Express & FastAPI → Claude-ready in 3 minutes.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zyx77550/sparda.git"
  },
  "homepage": "https://github.com/zyx77550/sparda#readme",
  "bugs": {
    "url": "https://github.com/zyx77550/sparda/issues"
  },
  "bin": {
    "sparda": "./src/index.js"
  },
  "scripts": {
    "test": "vitest run",
    "test:router": "node tests/router-selftest.cjs",
    "test:all": "vitest run && node tests/router-selftest.cjs",
    "coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,cjs,mjs}\"",
    "format:check": "prettier --check \"**/*.{js,cjs,mjs}\""
  },
  "files": [
    "src",
    "templates",
    "!templates/*.bak",
    "demo-app",
    "README.md",
    "LICENSE",
    "SKILL.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "ai",
    "express",
    "fastapi",
    "codegen"
  ],
  "author": "Residual Labs (residual-labs.fr)",
  "license": "BUSL-1.1",
  "dependencies": {
    "@babel/parser": "7.26.5",
    "@babel/traverse": "7.26.5",
    "@clack/prompts": "0.9.1",
    "@modelcontextprotocol/sdk": "1.29.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@vitest/coverage-v8": "^3.2.6",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "express": "^4.21.0",
    "globals": "^15.15.0",
    "prettier": "^3.8.4",
    "vitest": "^3.2.6"
  }
}
