{
  "name": "sparda-mcp",
  "version": "0.30.0",
  "mcpName": "io.github.zyx77550/sparda-mcp",
  "description": "Compile backends to behavior graphs. Statically prove security, simulate APIs, and replay bugs.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zyx77550/sparda.git"
  },
  "homepage": "https://github.com/zyx77550/sparda#readme",
  "bugs": {
    "url": "https://github.com/zyx77550/sparda/issues"
  },
  "bin": {
    "sparda": "./src/index.js"
  },
  "scripts": {
    "test": "vitest run",
    "test:router": "node tests/router-selftest.cjs",
    "test:all": "vitest run && node tests/router-selftest.cjs",
    "coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,cjs,mjs}\"",
    "format:check": "prettier --check \"**/*.{js,cjs,mjs}\""
  },
  "files": [
    "src",
    "templates",
    "!templates/*.bak",
    "demo-app",
    "README.md",
    "LICENSE",
    "SKILL.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "ai",
    "express",
    "fastapi",
    "codegen"
  ],
  "author": "Residual Labs (residual-labs.fr)",
  "license": "BUSL-1.1",
  "dependencies": {
    "@babel/parser": "7.26.5",
    "@babel/traverse": "7.26.5",
    "@clack/prompts": "0.9.1",
    "@modelcontextprotocol/sdk": "1.29.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "express": "^5.2.1",
    "globals": "^17.7.0",
    "prettier": "^3.8.4",
    "vitest": "^4.1.10"
  }
}
